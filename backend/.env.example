# Server
PORT=3000
NODE_ENV=development

# MongoDB — production: mongodb://user:pass@host:27017/tastystation
# Dev fallback: automatically uses mongodb-memory-server if unreachable
MONGO_URI=mongodb://localhost:27017/tastystation

# JWT — generate a long random string for production
JWT_SECRET=tasty_station_dev_secret_change_in_production_2025

# Redis (optional — set REDIS_SKIP=true to disable caching)
REDIS_SKIP=true
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://default:password@host:6379

# Cloudinary (for menu item images — register at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# === FURS (Slovenian fiscal system) ===
# Omogoči/onemogoči davčno potrjevanje računov
FURS_ENABLED=false
# Test mode (true = FURS test, false = produkcija)
FURS_TEST_MODE=true
# Pot do .p12 ali .pem certifikata (prenesi z https://edavki.durs.si/)
FURS_CERT_PATH=
# Geslo certifikata
FURS_CERT_PASSWORD=
# Default davčna številka (če Outlet nima svoje)
FURS_DEFAULT_TAX_NUMBER=

# === Email (SMTP) ===
# Omogoči/onemogoči pošiljanje email obvestil
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Tasty Station POS
SMTP_FROM_EMAIL=noreply@tastystation.si

# === Google Gemini AI (inventory forecast) ===
# Brez API ključa inventoryForecast.controller fallback-a na statistiko.
# Pridobi na https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === Frontend (Vite) ===
# Backend URL za frontend (brez /api). V produkciji nastavi na tvoj deploy.
# Default: http://localhost:3000 (dev) ali https://tastystation-bg.vercel.app
# VITE_API_BASE_URL=https://tvoj-backend.com
